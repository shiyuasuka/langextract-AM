498, "alignment": "match_exact"}, {"extraction_class": "composition", "text": "T42", "char_start": 2781, "char_end": 2784, "alignment": "match_exact"}, {"extraction_class": "process", "text": "applied a remelting procedure to fabricate the T42 RHEA", "char_start": 5066, "char_end": 5098, "alignment": "match_lesser"}, {"extraction_class": "composition", "text": "T42", "char_start": 1068, "char_end": 1071, "alignment": "match_fuzzy"}, {"extraction_class": "process", "text": "additive manufacturing (AM) with remelting procedure", "char_start": null, "char_end": null, "alignment": null}, {"extraction_class": "property", "text": "yield strength of approximately 1030 MPa", "char_start": 5181, "char_end": 5221, "alignment": "match_exact"}, {"extraction_class": "property", "text": "fracture strain of 22.5 %", "char_start": 5228, "char_end": 5253, "alignment": "match_exact"}, {"extraction_class": "property", "text": "yield strength decreased to ~681 MPa", "char_start": 5361, "char_end": 5375, "alignment": "match_lesser"}, {"extraction_class": "property", "text": "fracture strain increased to 27.8 %", "char_start": 5440, "char_end": 5475, "alignment": "match_exact"}, {"extraction_class": "property", "text": "yield strength decreased to ~661 MPa", "char_start": 5673, "char_end": 5687, "alignment": "match_lesser"}, {"extraction_class": "property", "text": "fracture strain decreased to ~16.8 %", "char_start": 5763, "char_end": 5799, "alignment": "match_exact"}, {"extraction_class": "property", "text": "a slight decrease (approximately 25 MPa) in the yield strength", "char_start": 5886, "char_end": 5948, "alignment": "match_exact"}, {"extraction_class": "property", "text": "a significant decrease in the fracture strain", "char_start": 5953, "char_end": 5998, "alignment": "match_exact"}, {"extraction_class": "property", "text": "local range lattice strain of 3.68 %", "char_start": 4608, "char_end": 4644, "alignment": "match_fuzzy"}, {"extraction_class": "composition", "text": "T42", "char_start": 234, "char_end": 237, "alignment": "match_fuzzy"}, {"extraction_class": "process", "text": "Not explicitly described in the provided text regarding general fabrication, but related to tensile - test samples which are as - fabricated", "char_start": null, "char_end": null, "alignment": null}, {"extraction_class": "property", "text": "decrease in the yield strength to ~661 MPa", "char_start": 157, "char_end": 199, "alignment": "match_exact"}, {"extraction_class": "property", "text": "fracture strain decreased to ~16.8 %", "char_start": 263, "char_end": 299, "alignment": "match_exact"}, {"extraction_class": "property", "text": "a slight decrease (approximately 25 MPa) in the yield strength", "char_start": 386, "char_end": 448, "alignment": "match_exact"}, {"extraction_class": "property", "text": "a significant decrease in the fracture strain (~7.5 %)", "char_start": 453, "char_end": 507, "alignment": "match_exact"}, {"extraction_class": "composition", "text": "HfNbTiZrTa", "char_start": 1416, "char_end": 1426, "alignment": "match_fuzzy"}, {"extraction_class": "composition", "text": "AM - fabricated superalloy", "char_start": 901, "char_end": 925, "alignment": "match_fuzzy"}, {"extraction_class": "composition", "text": "as - cast RHEAs", "char_start": 871, "char_end": 884, "alignment": "match_exact"}, {"extraction_class": "composition", "text": "Ni - based superalloys", "char_start": 1815, "char_end": 1823, "alignment": "match_lesser"}, {"extraction_class": "composition", "text": "T42", "char_start": 798, "char_end": 801, "alignment": "match_exact"}, {"extraction_class": "process", "text": "remelting procedure", "char_start": 3364, "char_end": 3383, "alignment": "match_fuzzy"}, {"extraction_class": "process", "text": "modelling the tensile properties using the DAMASK package and a dislocation - based crystal plasticity constitutive model, creating polycrystalline representative volume elements (RVEs) via the DEREAM3D package, meshing RVEs into 60 × 60 ×